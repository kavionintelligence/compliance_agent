# Express Server Settings
PORT=3000
NODE_ENV=production

# MongoDB Connection String (MongoDB Atlas recommended for Vercel)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/byosync_compliance?appName=Cluster0

# JWT Authentication Secrets (use long random strings in production)
JWT_SECRET=change_me_to_a_long_random_secret
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret

# Optional LLM provider keys
GEMINI_API_KEY=
OPENAI_API_KEY=
