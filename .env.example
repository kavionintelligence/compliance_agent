# Express Server Settings
PORT=3000
NODE_ENV=production

# MongoDB Connection String (MongoDB Atlas recommended for Vercel)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/byosync_compliance?appName=Cluster0

# JWT Authentication Secrets (use long random strings in production)
JWT_SECRET=change_me_to_a_long_random_secret
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret

# Vertex AI — GCP project and region
# The Gemini model runs on Vertex AI in this project and region.
VERTEX_PROJECT=compliance-app-498606
VERTEX_LOCATION=us-central1

# Vertex AI credentials
#
#   LOCAL DEV (your laptop):
#     Run once:  gcloud auth application-default login
#     The SDK finds the ADC file automatically — no env var needed.
#
#   VERCEL — Workload Identity Federation (recommended, no key file needed):
#     GCP org policies often block service account key creation.
#     WIF uses Vercel's OIDC token instead. One-time GCP setup:
#
#     PROJECT_NUMBER=142872487244
#     gcloud iam workload-identity-pools create "vercel-pool" --location="global"
#     gcloud iam workload-identity-pools providers create-oidc "vercel-provider" \
#       --location="global" --workload-identity-pool="vercel-pool" \
#       --attribute-mapping="google.subject=assertion.sub" \
#       --issuer-uri="https://oidc.vercel.com" --allowed-audiences="https://vercel.com"
#     gcloud iam service-accounts add-iam-policy-binding \
#       "byosync-vertex-caller@compliance-app-498606.iam.gserviceaccount.com" \
#       --role="roles/iam.workloadIdentityUser" \
#       --member="principalSet://iam.googleapis.com/projects/${PROJECT_NUMBER}/locations/global/workloadIdentityPools/vercel-pool/*"
#     gcloud iam workload-identity-pools create-cred-config \
#       "projects/${PROJECT_NUMBER}/locations/global/workloadIdentityPools/vercel-pool/providers/vercel-provider" \
#       --service-account="byosync-vertex-caller@compliance-app-498606.iam.gserviceaccount.com" \
#       --credential-source-file="/tmp/vercel-oidc-token" --credential-source-type="text" \
#       --output-file="vercel-wif-config.json"
#
#     Then in Vercel:
#       1. Project Settings -> General -> OpenID Connect Token -> Enable
#       2. Environment Variables -> GOOGLE_APPLICATION_CREDENTIALS_JSON = <contents of vercel-wif-config.json>
#
#   VERCEL — Service account key (if org policy allows key creation):
#     Create SA key JSON and paste full contents here.
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Optional environment name — controls which RemoteConfig row is loaded first.
# Typically "production" or "dev".
# CONFIG_ENV=production

# Optional: public API URL written into remote config during seeding
# API_BASE_URL=https://compliance-agent-o8o3.vercel.app
